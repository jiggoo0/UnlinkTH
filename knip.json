{
  "$schema": "https://knip.dev/schema-json",
  "next": {
    "entry": [
      "app/**/page.{tsx,ts}",
      "app/**/layout.{tsx,ts}",
      "app/**/loading.{tsx,ts}",
      "app/**/error.{tsx,ts}",
      "app/**/not-found.{tsx,ts}",
      "app/**/route.{tsx,ts}",
      "app/**/robots.{tsx,ts}",
      "app/**/sitemap.{tsx,ts}",
      "mdx-components.tsx",
      "middleware.ts"
    ]
  },
  "project": ["**/*.{ts,tsx,mjs}"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@img/sharp-wasm32",
    "@next/swc-android-arm64",
    "autoprefixer",
    "tailwindcss",
    "tailwindcss-animate",
    "sharp"
  ]
}
