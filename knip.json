{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "next": {
    "entry": [
      "next.config.{ts,js,mjs}",
      "app/**/{page,layout,loading,error,not-found,global-error,route,template,default}.{tsx,ts}",
      "app/{robots,sitemap}.ts",
      "mdx-components.tsx",
      "proxy.ts"
    ]
  },
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.ts",
    "constants/**/*.ts",
    "types/**/*.ts"
  ],
  "ignore": [
    "content/**/*.mdx",
    ".next/**",
    "node_modules/**",
    "public/**",
    "scripts/**"
  ],
  "ignoreDependencies": [
    "@tailwindcss/postcss",
    "tailwindcss-animate",
    "tw-animate-css",
    "prettier-plugin-tailwindcss",
    "remark-frontmatter",
    "remark-gfm",
    "@next/bundle-analyzer",
    "@tailwindcss/typography",
    "eslint-config-next",
    "tailwindcss",
    "@next/eslint-plugin-next"
  ],
  "ignoreBinaries": ["echo"]
}
