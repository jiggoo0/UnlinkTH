{
  "$schema": "https://knip.dev/schema-json",
  "entry": [
    "app/**/loading.tsx",
    "app/**/error.tsx",
    "app/**/not-found.tsx",
    "app/**/route.ts",
    "mdx-components.tsx"
  ],
  "project": ["**/*.{ts,tsx,mjs}"],
  "ignoreExportsUsedInFile": true,
  "ignore": ["lib/blob.ts"],
  "ignoreDependencies": [
    "@radix-ui/*",
    "autoprefixer",
    "tailwindcss",
    "tailwindcss-animate",
    "@vercel/blob",
    "google-auth-library",
    "sharp",
    "@img/sharp-wasm32",
    "@next/swc-android-arm64"
  ]
}
